{
  "name": "production-frontend",
  "version": "1.0.0",
  "description": "Production-ready frontend starter built with HTML5, Tailwind CSS, and Vanilla JavaScript.",
  "type": "module",
  "private": true,
  "scripts": {
    "clean": "rimraf dist",
    "copy": "node scripts/copy.mjs",
    "build:css": "cross-env NODE_ENV=production postcss src/css/main.css -o dist/css/main.css",
    "build": "npm run clean && npm run copy && npm run build:css",
    "watch:css": "postcss src/css/main.css -o dist/css/main.css --watch",
    "watch:files": "node scripts/watch.mjs",
    "watch": "concurrently -k -n CSS,FILES -c blue,green \"npm:watch:css\" \"npm:watch:files\"",
    "predev": "npm run clean && npm run copy",
    "dev": "concurrently -k -n WATCH,SERVE -c magenta,cyan \"npm run watch\" \"live-server dist --port=3000 --no-browser --entry-file=index.html\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "html5",
    "tailwindcss",
    "vanilla-js",
    "frontend",
    "starter",
    "boilerplate"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "cssnano": "^7.0.6",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "live-server": "^1.2.2",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead"
  ]
}
